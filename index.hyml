<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ShopZone — Premium E-Commerce</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Fraunces:wght@700;900&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #fafaf8; --dark: #0f0f0f; --accent: #ff4d00;
      --accent2: #ffb800; --card: #ffffff; --muted: #888;
      --border: #e8e8e8; --text: #1a1a1a;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }
    a { text-decoration: none; color: inherit; }

    /* NAVBAR */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: var(--dark); padding: 0 5%;
      display: flex; justify-content: space-between; align-items: center;
      height: 65px; box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }
    .nav-logo { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 900; color: #fff; cursor: pointer; }
    .nav-logo span { color: var(--accent); }
    .nav-search {
      flex: 1; max-width: 500px; margin: 0 2rem;
      display: flex; align-items: center;
      background: #1e1e1e; border-radius: 8px;
      padding: 0.5rem 1rem; gap: 0.5rem; border: 1px solid #2a2a2a;
    }
    .nav-search input { flex: 1; background: none; border: none; outline: none; color: #fff; font-size: 0.9rem; font-family: 'DM Sans', sans-serif; }
    .nav-search input::placeholder { color: #555; }
    .nav-right { display: flex; align-items: center; gap: 1rem; }
    .nav-link { color: #aaa; font-size: 0.85rem; cursor: pointer; transition: color 0.3s; background: none; border: none; font-family: 'DM Sans', sans-serif; }
    .nav-link:hover { color: #fff; }
    .nav-cart {
      background: var(--accent); color: #fff;
      padding: 0.5rem 1.2rem; border-radius: 6px; border: none;
      cursor: pointer; font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem; font-weight: 600;
      display: flex; align-items: center; gap: 0.5rem;
      transition: background 0.3s;
    }
    .nav-cart:hover { background: #e04400; }
    .cart-badge {
      background: var(--accent2); color: #000;
      border-radius: 50%; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; font-weight: 700;
    }

    /* HERO */
    .hero {
      background: var(--dark); padding: 5% 5%;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 3rem; align-items: center; min-height: 520px;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; top: -100px; right: -100px;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,77,0,0.12) 0%, transparent 70%);
    }
    .hero-tag {
      display: inline-block; background: rgba(255,77,0,0.15);
      color: var(--accent); font-size: 0.78rem;
      padding: 0.3rem 0.8rem; border-radius: 20px;
      border: 1px solid rgba(255,77,0,0.3);
      margin-bottom: 1.5rem; font-weight: 500;
      letter-spacing: 1px; text-transform: uppercase;
      animation: fadeUp 0.8s ease both;
    }
    .hero h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 900; color: #fff; line-height: 1.1;
      margin-bottom: 1.2rem;
      animation: fadeUp 0.8s ease 0.2s both;
    }
    .hero h1 span { color: var(--accent); }
    .hero-desc { color: #aaa; line-height: 1.8; margin-bottom: 2rem; animation: fadeUp 0.8s ease 0.4s both; }
    .hero-btns { display: flex; gap: 1rem; animation: fadeUp 0.8s ease 0.6s both; }
    .btn-primary {
      background: var(--accent); color: #fff;
      padding: 0.9rem 2rem; border-radius: 8px; border: none;
      cursor: pointer; font-size: 0.95rem; font-weight: 700;
      font-family: 'DM Sans', sans-serif; transition: all 0.3s;
    }
    .btn-primary:hover { background: #e04400; transform: translateY(-2px); }
    .btn-secondary {
      background: transparent; color: #fff;
      padding: 0.9rem 2rem; border-radius: 8px;
      border: 1px solid #333; cursor: pointer;
      font-size: 0.95rem; font-weight: 600;
      font-family: 'DM Sans', sans-serif; transition: all 0.3s;
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
    .hero-stats { display: flex; gap: 2rem; margin-top: 2.5rem; animation: fadeUp 0.8s ease 0.8s both; }
    .stat-num { font-size: 1.8rem; font-weight: 800; color: #fff; font-family: 'Fraunces', serif; }
    .stat-label { color: #666; font-size: 0.8rem; }
    .hero-showcase {
      width: 380px; height: 380px; border-radius: 20px;
      background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
      display: flex; align-items: center; justify-content: center;
      font-size: 8rem; position: relative; border: 1px solid #333;
      animation: float 4s ease-in-out infinite;
      margin: auto;
    }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-15px)} }
    .hero-badge {
      position: absolute; top: 20px; right: 20px;
      background: var(--accent); color: #fff;
      padding: 0.5rem 0.8rem; border-radius: 8px; font-weight: 800;
    }
    @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

    /* SECTIONS */
    .section { padding: 5% 5%; }
    .section-alt { padding: 5% 5%; background: #f5f5f0; }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .section-title { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700; }
    .see-all { color: var(--accent); font-size: 0.9rem; cursor: pointer; font-weight: 600; background: none; border: none; font-family: 'DM Sans', sans-serif; }

    /* CATEGORIES */
    .categories { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem; }
    .cat-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 12px; padding: 1.5rem 1rem;
      text-align: center; cursor: pointer; transition: all 0.3s;
    }
    .cat-card:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 10px 30px rgba(255,77,0,0.1); }
    .cat-icon { font-size: 2.2rem; margin-bottom: 0.7rem; }
    .cat-name { font-size: 0.85rem; font-weight: 600; }
    .cat-count { font-size: 0.72rem; color: var(--muted); margin-top: 0.2rem; }

    /* PRODUCTS */
    .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
    .product-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden; cursor: pointer;
      transition: all 0.3s; position: relative;
    }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    .product-img {
      height: 200px; display: flex; align-items: center;
      justify-content: center; font-size: 5rem;
      background: linear-gradient(135deg, #f8f8f8, #eeeeee);
      position: relative;
    }
    .product-badge {
      position: absolute; top: 12px; left: 12px;
      padding: 0.2rem 0.6rem; border-radius: 6px;
      font-size: 0.7rem; font-weight: 700;
    }
    .badge-new { background: #00c853; color: #fff; }
    .badge-sale { background: var(--accent); color: #fff; }
    .badge-hot { background: var(--accent2); color: #000; }
    .wishlist-btn {
      position: absolute; top: 12px; right: 12px;
      width: 34px; height: 34px; border-radius: 50%;
      background: #fff; border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; cursor: pointer; opacity: 0; transition: opacity 0.3s;
    }
    .product-card:hover .wishlist-btn { opacity: 1; }
    .product-info { padding: 1.2rem; }
    .product-cat { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.3rem; }
    .product-name { font-weight: 700; font-size: 0.93rem; margin-bottom: 0.5rem; line-height: 1.4; }
    .product-rating { display: flex; align-items: center; gap: 0.3rem; margin-bottom: 0.7rem; }
    .stars { color: var(--accent2); font-size: 0.8rem; }
    .rating-count { font-size: 0.72rem; color: var(--muted); }
    .product-price { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .price-now { font-size: 1.15rem; font-weight: 800; }
    .price-was { font-size: 0.83rem; color: var(--muted); text-decoration: line-through; }
    .price-off { font-size: 0.75rem; color: #00c853; font-weight: 700; }
    .btn-cart {
      width: 100%; padding: 0.7rem;
      background: var(--dark); color: #fff;
      border: none; border-radius: 8px; cursor: pointer;
      font-size: 0.85rem; font-weight: 600;
      font-family: 'DM Sans', sans-serif; transition: all 0.3s;
    }
    .btn-cart:hover { background: var(--accent); }

    /* PROMO */
    .promo-banner {
      margin: 0 5% 5%;
      background: linear-gradient(135deg, #0f0f0f, #1a1a1a);
      border-radius: 20px; padding: 3rem 4rem;
      display: flex; justify-content: space-between; align-items: center;
      position: relative; overflow: hidden;
    }
    .promo-banner::before {
      content: ''; position: absolute; top: -50px; right: 150px;
      width: 300px; height: 300px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,184,0,0.12) 0%, transparent 70%);
    }
    .promo-tag { color: var(--accent2); font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 0.8rem; }
    .promo-title { font-family: 'Fraunces', serif; font-size: 2.5rem; font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 1rem; }
    .promo-title span { color: var(--accent); }
    .promo-emoji { font-size: 6rem; position: relative; z-index: 2; }

    /* TOAST */
    .toast {
      position: fixed; bottom: 2rem; right: 2rem; z-index: 999;
      background: var(--dark); color: #fff;
      padding: 1rem 1.5rem; border-radius: 10px;
      font-size: 0.9rem; font-weight: 600;
      display: flex; align-items: center; gap: 0.7rem;
      transform: translateY(100px); opacity: 0;
      transition: all 0.4s; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    .toast.show { transform: translateY(0); opacity: 1; }

    /* FOOTER */
    footer { background: var(--dark); color: #aaa; padding: 4rem 5% 2rem; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
    .footer-logo { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 900; color: #fff; margin-bottom: 1rem; display: block; }
    .footer-logo span { color: var(--accent); }
    .footer-desc { font-size: 0.88rem; line-height: 1.8; color: #666; }
    .footer-col h4 { color: #fff; font-weight: 700; margin-bottom: 1.2rem; font-size: 0.95rem; }
    .footer-col a { display: block; color: #666; font-size: 0.85rem; margin-bottom: 0.6rem; cursor: pointer; transition: color 0.3s; }
    .footer-col a:hover { color: var(--accent); }
    .footer-bottom { border-top: 1px solid #1e1e1e; padding-top: 2rem; display: flex; justify-content: space-between; font-size: 0.82rem; color: #555; }

    @media(max-width:768px) {
      .hero { grid-template-columns: 1fr; }
      .hero-showcase { display: none; }
      .categories { grid-template-columns: repeat(3,1fr); }
      .products-grid { grid-template-columns: repeat(2,1fr); }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      nav { padding: 0 3%; }
      .nav-search { display: none; }
    }
  </style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast"><span id="toast-msg">Added to cart!</span></div>

<!-- NAVBAR -->
<nav>
  <div class="nav-logo" onclick="location.href='index.html'">Shop<span>Zone</span></div>
  <div class="nav-search">
    <span>🔍</span>
    <input type="text" placeholder="Search products, brands..."/>
  </div>
  <div class="nav-right">
    <button class="nav-link" onclick="location.href='dashboard.html'">👤 My Account</button>
    <button class="nav-link" onclick="location.href='orders.html'">📦 Orders</button>
    <button class="nav-cart" onclick="location.href='cart.html'">
      🛒 Cart <span class="cart-badge" id="cartBadge">0</span>
    </button>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div>
    <div class="hero-tag">🔥 New Season Sale — Up to 70% Off</div>
    <h1>Shop the <span>Latest</span> Trends Online</h1>
    <p class="hero-desc">Discover thousands of premium products from top brands. Fast delivery, easy returns, and the best prices guaranteed across India.</p>
    <div class="hero-btns">
      <button class="btn-primary" onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">Shop Now →</button>
      <button class="btn-secondary" onclick="location.href='login.html'">Sign In</button>
    </div>
    <div class="hero-stats">
      <div><div class="stat-num">50K+</div><div class="stat-label">Products</div></div>
      <div><div class="stat-num">10M+</div><div class="stat-label">Customers</div></div>
      <div><div class="stat-num">4.9★</div><div class="stat-label">Rating</div></div>
    </div>
  </div>
  <div>
    <div class="hero-showcase">🛍️<div class="hero-badge">-70%</div></div>
  </div>
</div>

<!-- CATEGORIES -->
<div class="section">
  <div class="section-header">
    <h2 class="section-title">Shop by Category</h2>
    <button class="see-all">See All →</button>
  </div>
  <div class="categories">
    <div class="cat-card"><div class="cat-icon">📱</div><div class="cat-name">Electronics</div><div class="cat-count">2,340 items</div></div>
    <div class="cat-card"><div class="cat-icon">👗</div><div class="cat-name">Fashion</div><div class="cat-count">5,120 items</div></div>
    <div class="cat-card"><div class="cat-icon">🏠</div><div class="cat-name">Home & Living</div><div class="cat-count">1,890 items</div></div>
    <div class="cat-card"><div class="cat-icon">💄</div><div class="cat-name">Beauty</div><div class="cat-count">3,450 items</div></div>
    <div class="cat-card"><div class="cat-icon">⚽</div><div class="cat-name">Sports</div><div class="cat-count">980 items</div></div>
    <div class="cat-card"><div class="cat-icon">📚</div><div class="cat-name">Books</div><div class="cat-count">7,200 items</div></div>
  </div>
</div>

<!-- PRODUCTS -->
<div class="section-alt" id="products">
  <div class="section-header">
    <h2 class="section-title">Trending Products</h2>
    <button class="see-all">View All →</button>
  </div>
  <div class="products-grid">

    <div class="product-card" onclick="location.href='product.html?id=1'">
      <div class="product-img">📱<span class="product-badge badge-new">NEW</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Electronics</div>
        <div class="product-name">iPhone 15 Pro Max 256GB Natural Titanium</div>
        <div class="product-rating"><span class="stars">★★★★★</span><span class="rating-count">(2,341 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹1,29,999</span><span class="price-was">₹1,59,999</span><span class="price-off">-19%</span></div>
        <button class="btn-cart" onclick="event.stopPropagation();addCart('iPhone 15 Pro Max','₹1,29,999','📱')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card" onclick="location.href='product.html?id=2'">
      <div class="product-img">👟<span class="product-badge badge-sale">SALE</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Fashion</div>
        <div class="product-name">Nike Air Max 2024 Running Shoes</div>
        <div class="product-rating"><span class="stars">★★★★☆</span><span class="rating-count">(892 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹8,499</span><span class="price-was">₹12,999</span><span class="price-off">-35%</span></div>
        <button class="btn-cart" onclick="event.stopPropagation();addCart('Nike Air Max 2024','₹8,499','👟')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card" onclick="location.href='product.html?id=3'">
      <div class="product-img">⌚<span class="product-badge badge-hot">HOT</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Electronics</div>
        <div class="product-name">Apple Watch Series 9 GPS 45mm</div>
        <div class="product-rating"><span class="stars">★★★★★</span><span class="rating-count">(1,567 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹41,999</span><span class="price-was">₹49,900</span><span class="price-off">-16%</span></div>
        <button class="btn-cart" onclick="event.stopPropagation();addCart('Apple Watch Series 9','₹41,999','⌚')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card" onclick="location.href='product.html?id=4'">
      <div class="product-img">💻<span class="product-badge badge-new">NEW</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Electronics</div>
        <div class="product-name">MacBook Air M3 13-inch 16GB RAM</div>
        <div class="product-rating"><span class="stars">★★★★★</span><span class="rating-count">(3,210 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹1,14,900</span><span class="price-was">₹1,29,900</span><span class="price-off">-12%</span></div>
        <button class="btn-cart" onclick="event.stopPropagation();addCart('MacBook Air M3','₹1,14,900','💻')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card">
      <div class="product-img">🎧<span class="product-badge badge-hot">HOT</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Electronics</div>
        <div class="product-name">Sony WH-1000XM5 Wireless Headphones</div>
        <div class="product-rating"><span class="stars">★★★★★</span><span class="rating-count">(2,890 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹24,990</span><span class="price-was">₹34,990</span><span class="price-off">-29%</span></div>
        <button class="btn-cart" onclick="addCart('Sony WH-1000XM5','₹24,990','🎧')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card">
      <div class="product-img">👜<span class="product-badge badge-sale">SALE</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Fashion</div>
        <div class="product-name">Premium Leather Handbag Brown</div>
        <div class="product-rating"><span class="stars">★★★★☆</span><span class="rating-count">(445 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹3,299</span><span class="price-was">₹6,999</span><span class="price-off">-53%</span></div>
        <button class="btn-cart" onclick="addCart('Leather Handbag','₹3,299','👜')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card">
      <div class="product-img">📷<span class="product-badge badge-new">NEW</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Electronics</div>
        <div class="product-name">Canon EOS R50 Mirrorless Camera Kit</div>
        <div class="product-rating"><span class="stars">★★★★☆</span><span class="rating-count">(678 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹67,499</span><span class="price-was">₹79,999</span><span class="price-off">-16%</span></div>
        <button class="btn-cart" onclick="addCart('Canon EOS R50','₹67,499','📷')">🛒 Add to Cart</button>
      </div>
    </div>

    <div class="product-card">
      <div class="product-img">🏋️<span class="product-badge badge-sale">SALE</span><span class="wishlist-btn">❤️</span></div>
      <div class="product-info">
        <div class="product-cat">Sports</div>
        <div class="product-name">Fitness Resistance Bands Set (5 Pieces)</div>
        <div class="product-rating"><span class="stars">★★★★★</span><span class="rating-count">(1,234 reviews)</span></div>
        <div class="product-price"><span class="price-now">₹799</span><span class="price-was">₹1,999</span><span class="price-off">-60%</span></div>
        <button class="btn-cart" onclick="addCart('Resistance Bands Set','₹799','🏋️')">🛒 Add to Cart</button>
      </div>
    </div>

  </div>
</div>

<!-- PROMO -->
<div class="promo-banner">
  <div style="position:relative;z-index:2">
    <div class="promo-tag">⚡ Limited Time Offer</div>
    <div class="promo-title">Get <span>Extra 20% Off</span><br/>On All Electronics!</div>
    <button class="btn-primary" style="margin-top:1rem">Grab the Deal →</button>
  </div>
  <div class="promo-emoji">⚡📱</div>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-grid">
    <div>
      <span class="footer-logo">Shop<span>Zone</span></span>
      <p class="footer-desc">Your one-stop destination for everything you need. Quality products, unbeatable prices, and lightning-fast delivery across India.</p>
    </div>
    <div class="footer-col">
      <h4>Company</h4>
      <a>About Us</a><a>Careers</a><a>Press</a><a>Blog</a>
    </div>
    <div class="footer-col">
      <h4>Support</h4>
      <a>Help Centre</a><a onclick="location.href='orders.html'">Track Order</a><a>Returns</a><a>Contact Us</a>
    </div>
    <div class="footer-col">
      <h4>Account</h4>
      <a onclick="location.href='login.html'">Sign In</a>
      <a onclick="location.href='dashboard.html'">Dashboard</a>
      <a onclick="location.href='cart.html'">My Cart</a>
      <a onclick="location.href='orders.html'">My Orders</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2025 ShopZone — Built by Vigneshwaran S 🚀</span>
    <span>Made with ❤️ in India 🇮🇳</span>
  </div>
</footer>

<script>
  function addCart(name, price, emoji) {
    let cart = JSON.parse(localStorage.getItem('cart') || '[]');
    const existing = cart.find(i => i.name === name);
    if (existing) existing.qty++;
    else cart.push({ name, price, emoji, qty: 1 });
    localStorage.setItem('cart', JSON.stringify(cart));
    updateBadge();
    showToast('🛒 ' + name + ' added to cart!');
  }
  function updateBadge() {
    const cart = JSON.parse(localStorage.getItem('cart') || '[]');
    document.getElementById('cartBadge').textContent = cart.reduce((s,i)=>s+i.qty,0);
  }
  function showToast(msg) {
    const t = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'), 3000);
  }
  updateBadge();
</script>
</body>
</html>
